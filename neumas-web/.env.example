# Copy to .env.local and fill in values
# ---------------------------------------------------------------------------
# Backend
# ---------------------------------------------------------------------------
# Browser-safe API base. Keep this as /api so client requests use the Next.js
# same-origin proxy and do not depend on cross-origin CORS in production.
NEXT_PUBLIC_API_URL=/api

# Absolute backend origin used by server-side rewrites and route handlers.
BACKEND_URL=https://neumas-production.up.railway.app


# ---------------------------------------------------------------------------
# Supabase (public)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ---------------------------------------------------------------------------
# Supabase (server-only, NEVER expose to the browser)
# ---------------------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=your-jwt-secret

# ---------------------------------------------------------------------------
# Google OAuth
# ---------------------------------------------------------------------------
GOOGLE_CLIENT_ID=445878871304-bqd2ov5maibk89atuc2f08dmc6ienvn3.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://neumasfinal.vercel.app/auth/callback

# ---------------------------------------------------------------------------
# Agent OS (router-system registration)
# ---------------------------------------------------------------------------
AGENT_OS_URL=https://your-agent-os.up.railway.app
AGENT_OS_API_KEY=your-agent-os-api-key

# ---------------------------------------------------------------------------
# Environment ("development" | "staging" | "production")
# ---------------------------------------------------------------------------
ENVIRONMENT=development

# ---------------------------------------------------------------------------
# Sentry (optional — error tracking)
# ---------------------------------------------------------------------------
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_DSN=
# SENTRY_AUTH_TOKEN=   # CI/CD only — for source-map uploads
# SENTRY_ORG=

# ---------------------------------------------------------------------------
# PostHog (optional — product analytics)
# ---------------------------------------------------------------------------
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
