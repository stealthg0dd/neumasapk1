# =============================================================================
# Neumas Backend Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values

# Environment
ENV=dev
DEBUG=true

# ---------------------------------------------------------------------------
# DEV_MODE — set to true to bypass all LLM calls with deterministic stubs.
# Lets you run the full scan → shopping-list pipeline without any API keys.
# Always false in staging/prod.
# ---------------------------------------------------------------------------
DEV_MODE=false

# =============================================================================
# Sentry
# =============================================================================
# DSN for the neumas-backend Sentry project ("neumas-worker").
# Leave empty to disable Sentry in development.
SENTRY_DSN=
# Performance tracing sample rate (0.0–1.0). Use 1.0 in dev, 0.1 in prod.
SENTRY_TRACES_SAMPLE_RATE=0.1


# =============================================================================
# Supabase
# =============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Optional: Direct database connection for migrations/SQLAlchemy
# DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# =============================================================================
# Google OAuth
# =============================================================================
GOOGLE_CLIENT_ID=445878871304-bqd2ov5maibk89atuc2f08dmc6ienvn3.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://neumasfinal.vercel.app/auth/callback

# =============================================================================
# AI/LLM APIs
# =============================================================================
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# =============================================================================
# Redis
# =============================================================================
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# Security
# =============================================================================
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30

# =============================================================================
# CORS
# =============================================================================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# =============================================================================
# Agent OS / Router-system Registration
# =============================================================================
# Base URL of the ctechv agent OS service. Leave empty to skip registration.
AGENT_OS_URL=https://ctech-production.up.railway.app
# API key for authenticating with the agent OS (set in Railway env vars).
AGENT_OS_API_KEY=your-agent-os-api-key

# =============================================================================
# Celery
# =============================================================================
# Uses REDIS_URL by default for broker and backend
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0
