# =============================================================================
# Neumas Health Agent — Environment Variables
# =============================================================================
# Copy to .env and fill in values for local development.

# URL of the service itself (Railway sets RAILWAY_PUBLIC_DOMAIN automatically)
BASE_URL=http://localhost:8001

# The neumas backend service to monitor
NEUMAS_BACKEND_URL=https://neumas-production.up.railway.app

# Router-system (ctech) registration + heartbeat
AGENT_OS_URL=https://ctech-production.up.railway.app
AGENT_OS_API_KEY=your-agent-os-api-key

# How often to check backend health and send heartbeats (seconds, default 300)
HEARTBEAT_INTERVAL_SECONDS=300

# Application version (set to git SHA in CI/CD)
APP_VERSION=0.1.0

# Runtime environment
ENVIRONMENT=production
