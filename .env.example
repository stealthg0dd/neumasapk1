# =============================================================================
# Neumas — Monorepo Environment Variable Reference
# =============================================================================
# Copy this file to the relevant service directory as .env.local (web) or
# .env (backend) and fill in real values. Never commit files with real secrets.
#
# Prefix guide:
#   NEXT_PUBLIC_*   — bundled into the browser by Next.js (public, non-secret)
#   (no prefix)     — server-side only, never exposed to the browser
# =============================================================================


# =============================================================================
# SHARED — used by more than one service
# =============================================================================

# Runtime environment: development | staging | production
ENVIRONMENT=development


# =============================================================================
# neumas-web  (Next.js 16)
# =============================================================================


# -- Supabase (public) --------------------------------------------------------
# Your Supabase project URL — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# Supabase anon/public key — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key

# -- Supabase (server) --------------------------------------------------------
# Service-role key — bypasses RLS. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_JWT_SECRET=your-jwt-secret

# -- Google OAuth -------------------------------------------------------------
GOOGLE_CLIENT_ID=445878871304-bqd2ov5maibk89atuc2f08dmc6ienvn3.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://neumas-web.vercel.app/auth/callback

# -- Vercel/Production --------------------------------------------------------
# Ensure these match your Vercel project settings
NEXT_PUBLIC_VERCEL_URL=https://neumas-web.vercel.app

# -- Railway/Production -------------------------------------------------------
# Ensure these match your Railway project settings
RAILWAY_URL=https://neumas-production.up.railway.app

# -- Sentry -------------------------------------------------------------------
# Public Sentry DSN (client-side error tracking, safe to expose).
NEXT_PUBLIC_SENTRY_DSN=https://f149d55bb0fc5b21f18bb82311b84b05@o4511137130938368.ingest.de.sentry.io/4511153825054800

# Server-side Sentry DSN (for API route error reporting).
SENTRY_DSN=https://f149d55bb0fc5b21f18bb82311b84b05@o4511137130938368.ingest.de.sentry.io/4511153825054800

# Sentry auth token for source-map uploads (CI/CD only — never commit the real value).
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# Sentry organisation slug (visible in your Sentry URL: sentry.io/organizations/<slug>).
SENTRY_ORG=your-sentry-org-slug

# -- Agent OS / Router-system -------------------------------------------------
# Base URL of the agent OS service.
AGENT_OS_URL=https://your-agent-os.example.com

# API key for authenticating with the agent OS.
AGENT_OS_API_KEY=your-agent-os-api-key

# -- PostHog (analytics + session recording + feature flags) -----------------
# Project API key from posthog.com → Project Settings → Project API Key.
# Safe to expose to the browser.
NEXT_PUBLIC_POSTHOG_KEY=phc_your-posthog-project-key

# PostHog ingestion host. Change to your self-hosted instance if applicable.
# Defaults to https://us.i.posthog.com when not set.
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# -- Next.js misc -------------------------------------------------------------
# The public URL of the FastAPI backend.
# Leave empty to use the built-in /api/* proxy (recommended for production).
NEXT_PUBLIC_API_URL=

# Overrides the ENVIRONMENT value for the browser bundle.
NEXT_PUBLIC_ENVIRONMENT=development

# App version — used as the Sentry release identifier.
# Set to the git SHA or semver tag during CI/CD.
NEXT_PUBLIC_APP_VERSION=0.1.0


# =============================================================================
# neumas-backend  (FastAPI / Celery)
# =============================================================================

# Runtime flags
ENV=dev
DEBUG=true
# Set to true to bypass all LLM calls with deterministic stubs (no API keys needed).
DEV_MODE=false

# -- Supabase -----------------------------------------------------------------
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key
SUPABASE_ANON_KEY=eyJ...your-anon-key
# Supabase JWT secret — used to validate tokens locally.
SUPABASE_JWT_SECRET=your-jwt-secret
# Optional direct connection for migrations / SQLAlchemy
# DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# -- AI / LLM APIs ------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# -- Redis / Celery -----------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
# Railway private network URL (leave blank outside Railway)
# REDIS_PRIVATE_URL=redis://...internal
# CELERY_BROKER_URL defaults to REDIS_URL
# CELERY_RESULT_BACKEND defaults to REDIS_URL

# -- Security -----------------------------------------------------------------
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# -- Storage ------------------------------------------------------------------
STORAGE_BUCKET_RECEIPTS=scans
STORAGE_PUBLIC_RECEIPTS=false
STORAGE_SIGNED_URL_EXPIRY=3600

# -- CORS ---------------------------------------------------------------------
# Comma-separated list of allowed browser origins.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173


# =============================================================================
# neumas-web-vite  (Vite / React 18 — legacy)
# =============================================================================

VITE_API_BASE_URL=http://localhost:8000
